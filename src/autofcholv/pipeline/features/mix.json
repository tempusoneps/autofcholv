        "comment": "Đáy thấp hơn với volume cao hơn"
    },
    "high_position": {
        "type": "string",
        "name": "High Position",
        "comment": "Vị trí High so với Bollinger Band"
    },
    "low_position": {
        "type": "string",
        "name": "Low Position",
        "comment": "Vị trí Low"
    },
    "VWAP": {
        "type": "float",
        "name": "VWAP",
        "comment": "Volume Weighted Average Price"
    },
    "ATR14": {
        "type": "float",
        "name": "Atr 14",
        "comment": "Average True Range 14"
    },
    "ADX14": {
        "type": "float",
        "name": "Adx 14",
        "comment": "Average Directional Index 14"
    },
    "z_score": {
        "type": "float",
        "name": "Z Score",
        "comment": "Z-score của Close = (Price-MA)/Std"
    },
    "typical_price": {
        "type": "float",
        "name": "Typical Price",
        "comment": "(High+Low+Close)/3"
    },
    "DM": {
        "type": "float",
        "name": "Distance Moved",
        "comment": "DM = (Current High + Current Low) / 2 - (Previous High + Previous Low) / 2"
    },
    "VBR": {
        "type": "float",
        "name": "Volume Box Ratio",
        "comment": "VBR = Volume / (High - Low)"
    },
    "EOM": {
        "type": "float",
        "name": "Ease of Movement",
        "comment": "EOM = DM / VBR"
    },
    "keltner_channel": {
        "type": "float",
        "name": "Keltner Channel",
        "comment": "Keltner Channel = EMA20 ± ATR14"
