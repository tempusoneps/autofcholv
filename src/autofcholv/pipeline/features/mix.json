{
    "cs_ibs_n": {
        "type": "float",
        "name": "ibs n",
        "comment": "ibs_n = (close - lowest(n)) / (highest(n) - lowest(n))"
    },
    "is_fvg": {
        "type": "bool",
        "name": "Is FVG",
        "comment": "Fair Value Gap"
    },
    "is_lower_low_higher_volume": {
        "type": "bool",
